# --- Build ---
LLAMACPP_REF=feature/turboquant-kv-cache   # TheTom TurboQuant fork;
CUDA_ARCH=89               # RTX 4060 Ti (Ada)

# --- Model (auto-downloaded from HuggingFace on first start) ---
# -hf takes the repo (no tag); the exact GGUF filename goes in LLAMA_ARG_HF_FILE
# (the native env var for --hf-file). The part after ':' in -hf is a QUANT tag,
# NOT a filename. When LLAMA_ARG_HF_FILE is empty it is simply unused.
# Gemma 4 26B-A4B QAT (Q4 size, ~BF16 quality, native tool calling, 256K ctx).
MODEL_HF=unsloth/gemma-4-26B-A4B-it-qat-GGUF
LLAMA_ARG_HF_FILE=gemma-4-26B-A4B-it-qat-UD-Q4_K_XL.gguf
# Qwen3-Coder-30B-A3B REAP (~9.75 GB, coding-specialized) — uncomment to revert
# (uses a quant tag, so clear LLAMA_ARG_HF_FILE):
# MODEL_HF=lainlives/Qwen3-Coder-30B-A3B-Instruct_Pruned_REAP-15B-A3B-SafeTensors-Q4_K_M-GGUF:Q4_K_M
# LLAMA_ARG_HF_FILE=

# --- Server ---
PORT=8080
CTX_SIZE=262144            # Gemma 4 max (256K = 256*1024). Verified: ~12.6 GB
                           # VRAM with turbo KV. Fall back to 131072 if it OOMs.
N_GPU_LAYERS=99            # offload all transformer layers to GPU
# MoE expert layers offloaded to CPU. Model is 14.25 GB; at N_CPU_MOE=18 + 256k
# ctx, VRAM was 12.6/16 GB (~3.4 GB free). Lowered to 14 to pull more experts
# onto the GPU for speed while keeping a safety margin. If OOM, raise it; if
# nvidia-smi still shows free VRAM, lower further (one step at a time).
N_CPU_MOE=14
BATCH_SIZE=4096
UBATCH_SIZE=2048

# KV cache type. Video uses TurboQuant compressed KV (turbo4/turbo2).
# Requires the fork branch that supports these as --cache-type-k/v values;
# if the server fails to start, fall back to q8_0.
CACHE_TYPE_K=turbo4
CACHE_TYPE_V=turbo2

# --- Sampling (Gemma 4 recommended) ---
TEMP=1.0
TOP_P=0.95
TOP_K=64
# Qwen3-Coder recommended sampling — uncomment to revert:
# TEMP=0.7
# TOP_P=0.95
# TOP_K=20

# --jinja: model chat template so tool/function calling returns structured
#          tool_calls (required for the coding agent).
# --cache-ram 0: disable the prompt-cache save/restore that crashed mid-request
#          ("failed to restore kv cache" / checkpoint size mismatch).
# --threads 6: use all 6 CPU cores -- experts are offloaded to CPU via
#          N_CPU_MOE, so threads directly drive tok/s (was throttled at 2).
# --cache-reuse 256: KV prefix reuse (as in the video). NOTE: the server DISABLES
#          this while multimodal is loaded ("cache_reuse is not supported by
#          multimodal"), so it only takes effect in text-only mode (--no-mmproj).
# Vision ENABLED: no --no-mmproj, so -hf auto-downloads mmproj-BF16.gguf (~1.2 GB
#          extra VRAM). To go text-only and activate cache-reuse, add --no-mmproj.
# Dropped --mlock (RLIMIT_MEMLOCK denied it in-container anyway) and --no-mmap.
EXTRA_ARGS=--jinja --cache-ram 0 --no-mmproj --cache-reuse 256 --threads 6

# --- Cloudflare tunnel (cloudflared service) ---
# ROTATED token from Cloudflare Zero Trust. Keep out of git (.env is gitignored).
TUNNEL_TOKEN=CF_Token
